{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openfab.ai/schemas/spec.schema.json",
  "title": "OpenFab Spec",
  "description": "The spec-as-contract (PRD §4). Validation is mirrored in core::spec::Spec::validate.",
  "type": "object",
  "required": ["id", "intent", "acceptance"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1, "default": 1 },
    "intent": { "type": "string", "minLength": 1, "description": "the natural-language ask" },
    "context": { "type": "array", "items": { "type": "string" } },
    "language": { "type": "string" },
    "target_dir": { "type": "string", "default": "app" },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "check"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "check": { "type": "string", "minLength": 1, "description": "any executable command; exit 0 = pass" },
          "must_pass": { "type": "boolean", "default": true }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "human_signoff_required": { "type": "boolean", "default": true }
  }
}
